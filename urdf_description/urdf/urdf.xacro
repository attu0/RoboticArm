<?xml version="1.0" ?>
<robot name="urdf" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find urdf_description)/urdf/materials.xacro" />
  <xacro:include filename="$(find urdf_description)/urdf/urdf.trans" />
  <xacro:include filename="$(find urdf_description)/urdf/urdf.gazebo" />

  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-1.4210854715202004e-16 0.01997193071423041 -0.001498250638833376" rpy="0 0 0"/>
      <mass value="4.4888808326831455"/>
      <inertia ixx="0.005704" iyy="0.010214" izz="0.005704" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="second_link_1">
    <inertial>
      <origin xyz="-6.774902727458384e-06 0.014971627783500002 -0.00013818298140451206" rpy="0 0 0"/>
      <mass value="1.4823148625325708"/>
      <inertia ixx="0.001266" iyy="0.002377" izz="0.001705" ixy="-0.0" iyz="1.7e-05" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.0 -0.039972 0.001498" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/second_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.0 -0.039972 0.001498" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/second_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="third_link_1">
    <inertial>
      <origin xyz="-3.737930336089336e-18 0.08876551506405717 -0.0020782404508530626" rpy="0 0 0"/>
      <mass value="2.387528915395379"/>
      <inertia ixx="0.009546" iyy="0.000679" izz="0.0095" ixy="-0.0" iyz="0.000459" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0 -0.069972 0.001498" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/third_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0 -0.069972 0.001498" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/third_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="fourth_link_1">
    <inertial>
      <origin xyz="5.9445874542904334e-06 0.05885395838595783 -0.0026918084429297558" rpy="0 0 0"/>
      <mass value="1.6196524060997979"/>
      <inertia ixx="0.002338" iyy="0.000656" izz="0.002662" ixy="-1e-06" iyz="7.5e-05" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.0 -0.242611 0.024238" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/fourth_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.0 -0.242611 0.024238" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/fourth_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="fifth_link_1">
    <inertial>
      <origin xyz="0.001735674337229184 0.02229835595495555 -0.0010592459203292888" rpy="0 0 0"/>
      <mass value="0.4662210195037937"/>
      <inertia ixx="0.000115" iyy="0.00023" izz="0.000251" ixy="9e-06" iyz="1e-06" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.000129 -0.361211 0.029819" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/fifth_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.000129 -0.361211 0.029819" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find urdf_description)/meshes/fifth_link_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_rev" type="revolute">
    <origin xyz="0.0 0.039972 -0.001498" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="second_link_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit upper="6.283185" lower="0.0" effort="100" velocity="100"/>
  </joint>

  <joint name="second_rev" type="revolute">
    <origin xyz="0.0 0.03 0.0" rpy="0 0 0"/>
    <parent link="second_link_1"/>
    <child link="third_link_1"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
  </joint>

  <joint name="third_rev" type="revolute">
    <origin xyz="-0.0 0.172639 -0.02274" rpy="0 0 0"/>
    <parent link="third_link_1"/>
    <child link="fourth_link_1"/>
    <axis xyz="-1.0 -0.0 0.0"/>
    <limit upper="2.268928" lower="-0.872665" effort="100" velocity="100"/>
  </joint>

  <joint name="fourth_rev" type="revolute">
    <origin xyz="0.000129 0.1186 -0.005581" rpy="0 0 0"/>
    <parent link="fourth_link_1"/>
    <child link="fifth_link_1"/>
    <axis xyz="0.997169 -0.075141 0.002816"/>
    <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
  </joint>

  <ros2_control name="urdf_arm_control" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <joint name="base_rev">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">6.283185</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="second_rev">
      <command_interface name="position">
        <param name="min">-1.570796</param>
        <param name="max">1.570796</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="third_rev">
      <command_interface name="position">
        <param name="min">-0.872665</param>
        <param name="max">2.268928</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="fourth_rev">
      <command_interface name="position">
        <param name="min">-1.570796</param>
        <param name="max">1.570796</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
